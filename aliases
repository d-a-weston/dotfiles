alias zshr='source ~/.zshrc'
alias tmuxr='tmux source ~/.tmux.conf'

alias vf='vim $(fd --type f --hidden --follow | fzf)'
alias cdd='cd $(fd --type d . $HOME/Documents | fzf)'

alias tfi='terraform init'
alias tfp='terraform plan'
alias tfa='terraform apply -auto-approve'
alias tfd='terraform destroy -auto-approve'

alias obw='cd ~/Documents/Github/vault && git pull && git add . && git commit -m "update" && git push && cd -'
alias obr='cd ~/Documents/Github/vault && git pull && cd -'
